rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 파일/프레젠테이션: 본인만 읽기/쓰기
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 공유 문서: 누구나 읽기, 인증된 사용자 생성, 소유자만 삭제
    match /shared/{shareId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 공유 프리젠테이션: 누구나 읽기, 인증된 사용자 생성, 소유자만 삭제
    match /presentations-shared/{shareId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 코인 충전 webhook 멱등성 마커 — Cloud Function (admin SDK) 만 write.
    // 클라이언트는 접근 불필요.
    match /coinChargeProcessed/{sessionId} {
      allow read, write: if false;
    }

    // 결제 이력 — 본인만 읽기, write 는 Cloud Function (admin SDK).
    match /userProfiles/{uid}/coinCharges/{chargeId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 유저 프로필
    match /userProfiles/{uid} {
      // 수퍼관리자: 전체 프로필 읽기/수정 가능
      allow read, update: if request.auth != null && request.auth.token.email == 'tony@banya.ai';

      // 본인 프로필: 읽기 + 생성 + 허용된 필드만 업데이트
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastLoginAt',
          'coinBalance', 'coinSpent', 'coinEarned', 'lastSpentAt',
          'photoURL', 'displayName'
        ]);
    }
  }
}
